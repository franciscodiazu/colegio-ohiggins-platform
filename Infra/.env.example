# =============================================================================
# Variables de Entorno - Colegio O'Higgins Platform
# Archivo: /Infra/.env.example
# Proposito: Template versionable para desarrollo local
# USO: Copiar a .env y ajustar segun entorno
#   Windows: copy .env.example .env
#   Linux:   cp .env.example .env
# =============================================================================
# NOTA: Este archivo contiene valores placeholder.
# El archivo .env real esta en .gitignore y NO debe versionarse.
# En produccion (AWS EKS), las variables se definen en ConfigMaps/Secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# ENTORNO DE DESPLIEGUE
# -----------------------------------------------------------------------------
ENVIRONMENT=docker
COMPOSE_PROJECT_NAME=colegio-ohiggins

# -----------------------------------------------------------------------------
# BASE DE DATOS (MySQL 8.0)
# Interna en Docker network - sin exposicion al host
# -----------------------------------------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_ROOT_PASSWORD=root_example_change_in_prod
DB_NAME_STUDENTS=db_academic
DB_NAME_ATTENDANCE=db_record
DB_NAME_AUTH=colegio_auth_db
# DB_USERNAME se define en compose (default: app_colegio)
# DB_PASSWORD se define en compose (default: Ohiggins_Secur3_2026! - matching init.sql)
# Solo sobrescribir si se cambia la contraseña en init.sql
DB_USERNAME=app_colegio

# -----------------------------------------------------------------------------
# MICROSERVICIOS - URLs internas Docker
# -----------------------------------------------------------------------------
MS_STUDENTS_URL=http://ms-students:8081
MS_ATTENDANCE_URL=http://ms-attendance:8082

# -----------------------------------------------------------------------------
# GATEWAY BFF (Backend for Frontend)
# -----------------------------------------------------------------------------
BFF_PORT=8083
GATEWAY_PORT=8080

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
FRONTEND_PORT=5173
VITE_API_URL=http://api-gateway:8080

# -----------------------------------------------------------------------------
# CORS - Origenes permitidos
# Roles de prueba: alumno@colegioohiggins.com, profesor@colegioohiggins.com,
#                  apoderado@colegioohiggins.com
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://frontend:8080

# -----------------------------------------------------------------------------
# ACTUATOR - Monitoreo
# -----------------------------------------------------------------------------
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BACKEND=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=INFO
LOGGING_LEVEL_ORG_HIBERNATE=WARN

# -----------------------------------------------------------------------------
# JVM - Opciones de memoria
# -----------------------------------------------------------------------------
JAVA_OPTS=-Xmx512m -Xms256m -XX:+UseG1GC

# -----------------------------------------------------------------------------
# JWT (placeholder - rotar en produccion)
# -----------------------------------------------------------------------------
# JWT_SECRET=your-jwt-secret-min-32-chars
# JWT_EXPIRATION=1800000
