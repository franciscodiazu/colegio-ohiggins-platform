# =============================================================================
# Template de Variables de Entorno
# Archivo: /Infra/env.template
# Uso: Copiar como .env y configurar valores reales
# Seguridad: NUNCA versionar el archivo .env con credenciales reales
# =============================================================================

# -----------------------------------------------------------------------------
# ENTORNO DE DESPLIEGUE
# -----------------------------------------------------------------------------
# Valores posibles: local | docker | ministack | aws
ENVIRONMENT=docker

# Nombre del proyecto para Docker Compose
COMPOSE_PROJECT_NAME=colegio-ohiggins

# -----------------------------------------------------------------------------
# BASE DE DATOS (MySQL)
# -----------------------------------------------------------------------------
# Host de la base de datos
# - local: localhost
# - docker: mysql (nombre del servicio en docker-compose)
# - aws: <endpoint-rds>.amazonaws.com
DB_HOST=mysql

# Puerto de MySQL
DB_PORT=3306

# Contraseña del usuario root de MySQL
# SEGURIDAD: Usar contraseña fuerte y rotar regularmente
DB_ROOT_PASSWORD=ChangeThisRootPassword123!

# Nombres de las bases de datos
DB_NAME_STUDENTS=db_academic
DB_NAME_ATTENDANCE=db_record

# Credenciales de aplicación (NO usar root)
# Usuario creado por init.sql con privilegios limitados
DB_USERNAME=app_colegio
DB_PASSWORD=Ohiggins_Secur3_2026!

# -----------------------------------------------------------------------------
# MICROSERVICIOS - Configuración Interna
# -----------------------------------------------------------------------------
# Hosts y puertos de los microservicios
# En Docker: usar nombre del servicio como host
MS_STUDENTS_HOST=ms-students
MS_STUDENTS_PORT=8081

MS_ATTENDANCE_HOST=ms-attendance
MS_ATTENDANCE_PORT=8082

# URLs completas para el Gateway BFF
MS_STUDENTS_URL=http://ms-students:8081
MS_ATTENDANCE_URL=http://ms-attendance:8082

# -----------------------------------------------------------------------------
# GATEWAY BFF (Backend for Frontend)
# -----------------------------------------------------------------------------
# Puerto del servicio BFF
BFF_PORT=8080

# Host del BFF (para referencias internas)
BFF_HOST=backend-bff

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
# Host y puerto del frontend (para CORS)
FRONTEND_HOST=frontend
FRONTEND_PORT=5173

# URL de la API para el frontend
# IMPORTANTE: Para pruebas locales del navegador usar: http://localhost:8080
# Para entorno Docker usar: http://backend-bff:8080
# El valor por defecto en bffClient.js es 'http://localhost:8080' para desarrollo local
VITE_API_URL=http://backend-bff:8080

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Lista de orígenes permitidos separados por comas
# Incluir todos los dominios desde donde se accederá al backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://frontend:8080

# -----------------------------------------------------------------------------
# ACTUATOR (Monitoreo y Health Checks)
# -----------------------------------------------------------------------------
# Endpoints expuestos para monitoreo
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics

# Nivel de detalle en health endpoint
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Nivel de logging por ambiente
# DEBUG para desarrollo, INFO/WARN para producción
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BACKEND=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=INFO
LOGGING_LEVEL_ORG_HIBERNATE=WARN

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE JVM (Opcional)
# -----------------------------------------------------------------------------
# Opciones de memoria para Java
JAVA_OPTS=-Xmx512m -Xms256m -XX:+UseG1GC

# -----------------------------------------------------------------------------
# SEGURIDAD ADICIONAL (Para futura implementación)
# -----------------------------------------------------------------------------
# JWT Secret (generar valor aleatorio fuerte en producción)
# JWT_SECRET=your-jwt-secret-here-min-32-chars

# Habilitar HTTPS (true/false)
# HTTPS_ENABLED=false

# Timeouts (en segundos)
# REQUEST_TIMEOUT=30
# CONNECTION_TIMEOUT=10

# =============================================================================
# INSTRUCCIONES DE USO:
# =============================================================================
# 1. Copiar este archivo: cp env.template .env
# 2. Editar .env con valores reales
# 3. Asegurarse de que .env está en .gitignore
# 4. Ejecutar: docker-compose -f Infra/docker-compose.yml up
# =============================================================================
